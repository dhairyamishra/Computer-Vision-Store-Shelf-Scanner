# Managed vision provider. API keys stay in the API process and must never be
# exposed to the Expo client.
AI_PROVIDER=xai

# Optional FFmpeg executable overrides. Bundled binaries are used when omitted.
FFMPEG_PATH=
FFPROBE_PATH=
SHELF_AUDIT_DATA_DIRECTORY=

XAI_API_KEY=
XAI_MODEL=grok-4.5

OPENAI_API_KEY=
OPENAI_MODEL=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_MODEL=
